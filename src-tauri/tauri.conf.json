{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Aether",
  "version": "2.0.0",
  "identifier": "com.aether.desktop",
  "build": {
  "frontendDist": "../src",
  "beforeDevCommand": "",
  "beforeBuildCommand": ""
},
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Aether",
        "width": 1200,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 600,
        "decorations": false,
        "devtools": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}